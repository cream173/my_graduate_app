<%= form_with(model: health_record, local: true, data: { turbo: false }, class: "max-w-md mx-auto mt-20 mb-32 bg-white rounded-[40px] p-8 shadow-sm border border-stone-100 relative overflow-hidden") do |f| %>
  
  <h1 class="text-center text-3xl font-serif">体調記録</h1>
  <p class="text-center text-[10px] text-stone-400 tracking-widest uppercase font-light pb-12">The Journey of Balance</p>
  
  <%# 今日の気分 %>
  <section class="mb-10">
    <label class="block text-center font-bold mb-4">気分はいかがですか？</label>
    <div class="flex justify-between gap-2">
      <% [
        { value: 1, label: 'ごきげん', icon: '😊' },
        { value: 2, label: 'ふつう', icon: '🙂' },
        { value: 3, label: '不安', icon: '😔' },
        { value: 4, label: 'しんどい', icon: '😢' },
        { value: 5, label: 'イライラ', icon: '😡' }
      ].each do |feeling| %>
        <label class="flex-1 text-center cursor-pointer group rounded-xl border-2 border-stone-100 p-2 transition-all
                      [&:has(:checked)]:bg-stone-50 [&:has(:checked)]:border-stone-400 grayscale [&:has(:checked)]:grayscale-0">
          <%= f.radio_button :feeling, feeling[:value], class: "hidden" %>
            <span class="text-2xl block"><%= feeling[:icon] %></span>
            <span class="text-xs mt-1 block"><%= feeling[:label] %></span>
        </label>
      <% end %>
    </div>
  </section>

  <%# スライダー項目%>
<div class="mb-10">
    <% [
      { field: :stress_level, label: 'ストレス', min: '低', max: '高' },
      { field: :fatigue_level, label: 'からだの疲れ', min: '低', max: '高' },
      { field: :sleep_level, label: 'ねむりの質', min: 'ぐっすり', max: 'うとうと' }
    ].each do |range| %>
      <div class="space-y-1">
        <div class="flex justify-between items-center">
          <label class="font-bold"><%= range[:label] %></label>
          <span class="hidden" id="<%= range[:field] %>-val">0</span>
        </div>

        <%# DBに保存される値の隠しスペース%>
        <%= f.hidden_field range[:field], value: 0, id: "#{range[:field]}-hidden" %>

        <%# スライダーの見た目 %>
        <%= range_field_tag "#{range[:field]}_display", 0, min: 0, max: 100,
            class: "w-full h-2 rounded-lg appearance-none cursor-pointer accent-stone-400",
            style: "background: linear-gradient(to right, #a8a29e 0%, #e7e5e4 0%);",
            oninput: "
              const val100 = this.value;
              const val5 = Math.round(val100 / 20);
              this.style.background = `linear-gradient(to right, #a8a29e ${val100}%, #e7e5e4 ${val100}%)`;
              document.getElementById('#{range[:field]}-val').innerText = val5;
              document.getElementById('#{range[:field]}-hidden').value = val5;
            " %>

        <div class="flex justify-between text-[10px] text-stone-400">
          <span><%= range[:min] %></span>
          <span><%= range[:max] %></span>
        </div>
      </div>
    <% end %>
  </div>

  <%# 気になる不調 %>
  <div class="space-y-4 mb-12">
  <label class="block font-bold">今日の気になる不調</label>
  <div class="flex flex-wrap gap-2">
    <%= f.collection_check_boxes :symptom_ids, Symptom.all, :id, :name do |b| %>
      <label class="cursor-pointer group">
        <%= b.check_box class: "hidden peer" %>
        
        <%# ボタン部分 %>
        <span class="inline-block px-3 py-1 rounded-full border border-stone-200 bg-stone-50 text-sm 
                     peer-checked:bg-[#d17770] peer-checked:text-white 
                     transition-all duration-200 hover:bg-stone-200">
          <%= b.text %>
        </span>
      </label>
    <% end %>
  </div>
</div>

  <%# メモ %>
  <div class="space-y-2">
    <label class="font-bold">メモ</label>
    <%= f.text_area :memo, placeholder: "今の気持ちを自由に書いてみてくださいね", 
        class: "w-full rounded-2xl border-stone-200 bg-stone-50 p-4 focus:ring-stone-500 focus:border-stone-500 min-h-[100px]" %>
  </div>

  <div class="space-y-3 pt-4">
    <%= f.submit "記録を保存する", 
        class: "w-full py-4 bg-[#d17770] text-white rounded-xl shadow-lg hover:bg-[#cc6a63] transition-colors cursor-pointer" %>
    
    <%= link_to "キャンセル", root_path, 
        class: "block w-full text-center py-2 text-sm hover:text-stone-600" %>
  </div>
<% end %>