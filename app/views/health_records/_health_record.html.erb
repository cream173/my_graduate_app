<div class="max-w-md mx-auto bg-white rounded-[40px] p-8 shadow-sm border border-gray-60 relative overflow-hidden px-8 space-y-6">
  <div class="flex justify-between items-start mb-5">
    <div>
      <div class="flex items-baseline gap-2">
        <h2 class="text-2xl font-light font-['Hiragino_Mincho_ProN'] text-[#6B5E4C] leading-none">
          <%= health_record.created_at.strftime('%Y年%m月%d日') %>
        </h2>

    <div class="flex items-baseline gap-1">
      <%# 編集ボタン %>
      <%= link_to edit_health_record_path(health_record), title: "編集", class: "text-gray-300 hover:text-[#8C9B8A] transition-colors" do %>
        <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 16 16" fill="currentColor" class="size-4">
          <path fill-rule="evenodd" d="M11.013 2.513a1.75 1.75 0 0 1 2.475 2.474L6.226 12.25a2.751 2.751 0 0 1-.892.596l-2.047.848a.75.75 0 0 1-.98-.98l.848-2.047a2.75 2.75 0 0 1 .596-.892l7.262-7.261Z" clip-rule="evenodd" />
        </svg>
      <% end %>

      <%# 削除ボタン %>
      <%= button_to health_record_path(health_record), title: "削除",
                    method: :delete, 
                    form: { data: { turbo_confirm: "この記録を削除しますか？" } }, 
                    class: "text-gray-300 hover:text-red-400 transition-colors" do %>
        <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 16 16" fill="currentColor" class="size-4">
          <path fill-rule="evenodd" d="M5 3.25V4H2.75a.75.75 0 0 0 0 1.5h.3l.815 8.15A1.5 1.5 0 0 0 5.357 15h5.285a1.5 1.5 0 0 0 1.493-1.35l.815-8.15h.3a.75.75 0 0 0 0-1.5H11v-.75A2.25 2.25 0 0 0 8.75 1h-1.5A2.25 2.25 0 0 0 5 3.25Zm2.25-.75a.75.75 0 0 0-.75.75V4h3v-.75a.75.75 0 0 0-.75-.75h-1.5ZM6.05 6a.75.75 0 0 1 .787.713l.275 5.5a.75.75 0 0 1-1.498.075l-.275-5.5A.75.75 0 0 1 6.05 6Zm3.9 0a.75.75 0 0 1 .712.787l-.275 5.5a.75.75 0 0 1-1.498-.075l.275-5.5a.75.75 0 0 1 .786-.711Z" clip-rule="evenodd" />
        </svg>
      <% end %>
    </div>
  </div>
    <p class="text-[10px] text-gray-400 mb-1 tracking-tighter font-light">
      <%= health_record.created_at.strftime('%a') %> 
    </p>
</div>

  <%# 右側：気分アイコン（今のコード） %>
        <div class="text-center">
          <span class="text-3xl"><%= feeling_icon(health_record.feeling) %></span>
          <p class="text-[10px] text-gray-400 mt-1"><%= feeling_label(health_record.feeling) %></p>
        </div>
      </div>

        <%# ゲージ表示 %>
        <div class="space-y-4 mb-8">
          <% [
            { label: 'ストレス', val: health_record.stress_level, color: 'bg-[#B5B2A1]' },
            { label: '疲労度', val: health_record.fatigue_level, color: 'bg-[#D1C7A7]' },
            { label: '睡眠の質', val: health_record.sleep_level, color: 'bg-[#A67B7B]' }
          ].each do |param| %>
            <div class="space-y-1">
              <div class="flex justify-between text-[11px] text-gray-500 font-medium px-1">
                <span><%= param[:label] %></span>
              </div>
              <div class="h-[3px] w-full bg-gray-100 rounded-full overflow-hidden">
                <div class="<%= param[:color] %> h-full" style="width: <%= param[:val] * 20 %>%"></div>
              </div>
            </div>
          <% end %>
        </div>

        <%# 気になる不調（バッジ） %>
        <div class="mb-8">
          <p class="text-[11px] text-gray-400 mb-3">気になる不調</p>
          <div class="flex flex-wrap gap-2">
            <%# 中間テーブルを実装済みなら record.symptoms.each に書き換え %>
            <span class="px-4 py-1.5 bg-[#F4F6F3] text-[#8C9B8A] text-xs rounded-full border border-gray-100">
              特になし
            </span>
          </div>
        </div>

        <%# 一言メモ %>
        <div class="pt-6 border-t border-gray-50">
          <p class="text-sm text-[#8C8273] leading-relaxed font-light">
            <%= health_record.memo %>
          </p>
        </div>
      </div>