<% content_for :page_title, "マイページ編集" %>

<div class="max-w-md mx-auto py-20 px-6">
  <div class="bg-white rounded-[40px] p-8 shadow-sm border border-stone-100 mb-10">
    <h1 class="text-center text-3xl">マイページ編集</h1>
    <p class="text-center pb-6 text-[10px] text-stone-400 tracking-widest uppercase font-light">Edit My page</p>
    
    <div class="space-y-6">
      <%= form_with(model: @user, url: mypage_path, method: :patch, local: true, class: "space-y-6") do |f| %>

        <div class="space-y-2">
          <%= f.label :name, "おなまえ", class: "block text-sm mb-1" %>
          <%= f.text_field :name, class: "block w-full border border-stone-300 rounded-xl px-4 py-3" %>
        </div>

        <div class="space-y-2">
          <%= f.label :email, "メールアドレス", class: "block text-sm mb-1" %>
          <%= f.email_field :email, class: "block w-full border border-stone-300 rounded-xl px-4 py-3" %>
        </div>

        <div class="pt-6">
          <%= f.submit "更新する", class: "w-full py-4 bg-[#d17770] hover:bg-[#cc6a63] text-white rounded-xl cursor-pointer" %>
        </div>

        <%= link_to "キャンセル", mypage_path, 
            class: "block w-full text-center ext-sm hover:text-stone-600" %>
      <% end %>
    </div>
  </div>
</div>