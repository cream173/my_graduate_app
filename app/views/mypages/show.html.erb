<% content_for :page_title, "マイページ" %>

<div class="max-w-md mx-auto py-10 px-6">
  <div class="bg-white rounded-[40px] p-8 shadow-sm border border-stone-100 my-10">
  <h1 class="text-center text-3xl">マイページ</h1>
  <p class="text-center pb-10 text-[10px] text-stone-400 tracking-widest uppercase font-light">My page</p>
    <div class="space-y-6">
      
      <%# 名前の表示 %>
      <div>
        <label class="block text-sm mb-1">おなまえ</label>
        <p class="text-lg border-b border-stone-100 pb-2">
          <%= @user.name %>
        </p>
      </div>

      <%# メールアドレスの表示 %>
      <div>
        <label class="block text-sm mb-1">メールアドレス</label>
        <p class="text-lg border-b border-stone-100 pb-2">
          <%= @user.email %>
        </p>
      </div>

    </div>
  </div>

  <%# 編集画面へのボタン %>
  <div class="space-y-3">
    <%= link_to "登録情報を変更する", edit_mypage_path, 
        class: "block w-full py-4 bg-[#d17770] text-white rounded-2xl text-center hover:bg-[#cc6a63] transition" %>
  </div>
</div>