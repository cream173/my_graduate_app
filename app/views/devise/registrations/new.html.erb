<div class="max-w-md mx-auto bg-white rounded-[40px] p-8 shadow-sm border border-stone-100 relative overflow-hidden space-y-6 my-20">
  <div class="flex flex-col items-center">
    <h1 class="text-center text-3xl">新規登録</h1>
    <p class="text-center pb-2 text-[10px] text-stone-400 tracking-widest uppercase font-light">Create Account</p>

    <%= form_for(resource, as: resource_name, url: registration_path(resource_name), html: { class: "w-full space-y-5" }) do |f| %>
      <%= render 'shared/error_message', object: resource %>

      <div class="field">
        <%= f.label :name, "おなまえ", class: "block text-sm mb-1" %>
        <%= f.text_field :name, autofocus: true, autocomplete: "name", placeholder: "からだ太郎",
            class: "block w-full border border-stone-300 rounded-xl px-4 py-3 focus:outline-none focus:ring-2 focus:ring-stone-400 focus:border-transparent transition" %>
      </div>

      <div class="field">
        <%= f.label :email, "メールアドレス", class: "block text-sm mb-1" %>
        <%= f.email_field :email, autocomplete: "email", placeholder: "example@mail.com",
            class: "block w-full border border-stone-300 rounded-xl px-4 py-3 focus:outline-none focus:ring-2 focus:ring-stone-400 focus:border-transparent transition" %>
      </div>

      <div class="field">
        <div class="flex justify-between items-end mb-1">
          <%= f.label :password, "パスワード", class: "block text-sm" %>
        </div>
        <%= f.password_field :password, autocomplete: "new-password", placeholder: "6文字以上半角英数字",
            class: "block w-full border border-stone-300 rounded-xl px-4 py-3 focus:outline-none focus:ring-2 focus:ring-stone-400 focus:border-transparent transition" %>
      </div>

      <div class="field">
        <%= f.label :password_confirmation, "パスワード (確認用)", class: "block text-sm mb-1" %>
        <%= f.password_field :password_confirmation, autocomplete: "new-password", placeholder: "6文字以上半角英数字",
            class: "block w-full border border-stone-300 rounded-xl px-4 py-3 focus:outline-none focus:ring-2 focus:ring-stone-400 focus:border-transparent transition" %>
      </div>

      <div class="actions pt-2">
        <%= f.submit "登録する", 
            class: "w-full bg-[#d17770] text-white font-light py-3 rounded-2xl shadow-md hover:bg-[#cc6a63] hover:shadow-lg transition cursor-pointer" %>
      </div>
    <% end %>

    <div class="w-full mt-8 border-t border-stone-100">
    </div>

<div class="mt-6 text-sm flex items-center justify-center gap-1 text-sm text-stone-500">
  <%= link_to "すでにアカウントをお持ちの方はこちら", new_session_path(resource_name), 
      class: "font-medium hover:underline transition-all" %>
    
  </div>
</div>
  </div>
</div>