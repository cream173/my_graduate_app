<div class="max-w-md mx-auto bg-white rounded-[40px] p-8 shadow-sm border border-stone-100 relative overflow-hidden space-y-6 my-10">
  <div class="flex flex-col items-center">
    <h1 class="text-center text-3xl">新規登録</h1>
    <p class="text-center pb-2 text-[10px] text-stone-400 tracking-widest uppercase font-light">Create Account</p>

    <%= form_for(resource, as: resource_name, url: registration_path(resource_name), html: { class: "w-full space-y-5" }) do |f| %>
      <%= render 'shared/error_message', object: resource %>

      <div class="field">
        <%= f.label :name, "なまえ", class: "block text-sm font-medium mb-1" %>
        <%= f.text_field :name, autofocus: true, autocomplete: "name",
            class: "block w-full border border-stone-300 rounded-xl px-4 py-3 shadow-sm focus:outline-none focus:ring-2 focus:ring-stone-400 focus:border-transparent transition" %>
      </div>

      <div class="field">
        <%= f.label :email, "メールアドレス", class: "block text-sm font-medium mb-1" %>
        <%= f.email_field :email, autocomplete: "email",
            class: "block w-full border border-stone-300 rounded-xl px-4 py-3 shadow-sm focus:outline-none focus:ring-2 focus:ring-stone-400 focus:border-transparent transition" %>
      </div>

      <div class="field">
        <div class="flex justify-between items-end mb-1">
          <%= f.label :password, "パスワード", class: "block text-sm font-medium" %>
          <% if @minimum_password_length %>
            <span class="text-[10px] font-light">(<%= @minimum_password_length %>文字以上)</span>
          <% end %>
        </div>
        <%= f.password_field :password, autocomplete: "new-password",
            class: "block w-full border border-stone-300 rounded-xl px-4 py-3 shadow-sm focus:outline-none focus:ring-2 focus:ring-stone-400 focus:border-transparent transition" %>
      </div>

      <div class="field">
        <%= f.label :password_confirmation, "パスワード確認用", class: "block text-sm font-medium mb-1" %>
        <%= f.password_field :password_confirmation, autocomplete: "new-password",
            class: "block w-full border border-stone-300 rounded-xl px-4 py-3 shadow-sm focus:outline-none focus:ring-2 focus:ring-stone-400 focus:border-transparent transition" %>
      </div>

      <div class="actions pt-2">
        <%= f.submit "登録する", 
            class: "w-full bg-[#d17770] text-white font-light py-3 rounded-2xl shadow-md hover:bg-[#cc6a63] hover:shadow-lg transition cursor-pointer" %>
      </div>
    <% end %>

    <div class="w-full mt-8 border-t border-stone-100">
    </div>

<div class="mt-6 flex items-center justify-center gap-1 text-sm text-stone-500">
  <span>すでにアカウントをお持ちの方は</span>
  <div class="hover:underline">
    <%= render "devise/shared/links" %>
  </div>
</div>
  </div>
</div>