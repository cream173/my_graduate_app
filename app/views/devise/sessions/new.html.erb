<div class="max-w-md mx-auto bg-white rounded-[40px] p-8 shadow-sm border border-stone-100 relative overflow-hidden space-y-6 my-20">
<div class="flex flex-col items-center">
  <h1 class="text-center text-3xl">ログイン</h1>
  <p class="text-center text-[10px] text-stone-400 tracking-widest uppercase font-light">Sign In</p>

<%= form_for(resource, as: resource_name, url: session_path(resource_name), html: { class: "w-full space-y-5" }) do |f| %>
  <%= render 'shared/error_message', object: resource %>

  <div class="field">
    <%= f.label :email, "メールアドレス", class: "block text-sm mb-1" %>
    <%= f.email_field :email, autofocus: true, autocomplete: "email", placeholder: "example@mail.com", 
    class: "block w-full border border-stone-300 rounded-xl px-4 py-3 focus:outline-none focus:ring-2 focus:ring-stone-400 focus:border-transparent transition" %>
  </div>

  <div class="field">
    <p><%= f.label :password, "パスワード", class: "block text-sm mb-1" %></p>
    <p><%= f.password_field :password, autocomplete: "current-password", placeholder: "6文字以上半角英数字",
    class: "block w-full border border-stone-300 rounded-xl px-4 py-3 focus:outline-none focus:ring-2 focus:ring-stone-400 focus:border-transparent transition" %></p>
  </div>

  <% if devise_mapping.rememberable? %>
    <div class="field flex items-center text-xs gap-1">
      <span><%= f.check_box :remember_me %></span>
      <span><%= f.label :次回から自動でログイン %></span>
    </div>
  <% end %>

  <%= f.submit "ログイン", 
    class: "w-full bg-[#d17770] text-white font-light py-3 rounded-2xl shadow-md hover:bg-[#cc6a63] hover:shadow-lg transition cursor-pointer" %>
  <% end %>

  <div class="w-full mt-8 border-t border-stone-100">
  </div>

<div class="mt-6 text-sm flex items-center justify-center gap-1">
  <%= link_to "アカウントをお持ちでない方はこちら", new_registration_path(resource_name), 
      class: "font-medium hover:underline transition-all" %>
</div>
</div>
</div>