<div class="flex flex-col items-center py-20 min-h-screen bg-[#fcfaf7]">
  <h1 class="text-3xl font-serif">今日も一日お疲れさま</h1>
  <div class="flex items-baseline mb-6">
    <span class="text-2xl"><%= current_user.name %>さん</span>
  </div>

  <div class="flex flex-row items-stretch justify-center gap-6 w-full max-w-5xl mb-12">
    <div class="flex-1 bg-white rounded-[40px] p-6 shadow-sm border border-stone-100 text-center flex flex-col items-center">
      <div class="flex items-center justify-center gap-2 mb-4">
        <span class="flex items-center gap-2 p-2 px-4 bg-stone-50 rounded-full text-emerald-800 text-sm font-bold">
          <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="currentColor" class="size-6">
            <path d="M18.375 2.25c-1.035 0-1.875.84-1.875 1.875v15.75c0 1.035.84 1.875 1.875 1.875h.75c1.035 0 1.875-.84 1.875-1.875V4.125c0-1.036-.84-1.875-1.875-1.875h-.75ZM9.75 8.625c0-1.036.84-1.875 1.875-1.875h.75c1.036 0 1.875.84 1.875 1.875v11.25c0 1.035-.84 1.875-1.875 1.875h-.75a1.875 1.875 0 0 1-1.875-1.875V8.625ZM3 13.125c0-1.036.84-1.875 1.875-1.875h.75c1.036 0 1.875.84 1.875 1.875v6.75c0 1.035-.84 1.875-1.875 1.875h-.75A1.875 1.875 0 0 1 3 19.875v-6.75Z" />
          </svg>
          <span>今週の体調バランス</span>
        </span>
      </div>

      <div class="w-full flex-grow flex items-center">
        <% [
          { label: "ストレス", val: @stress_percent || 0 },
          { label: "からだの疲れ", val: @fatigue_percent || 0 },
          { label: 'ねむりの質', val: @sleep_percent || 0 }
        ].each do |item| %>
          <div class="flex-1 flex flex-col items-center">
            <span class="text-[10px] pb-2"><%= item[:label] %></span>
            <div class="w-28 h-28 rounded-full flex items-center justify-center mb-2 relative"
                 style="background: conic-gradient(<%= 
                   if item[:val] >= 70 then "#c4232e" elsif item[:val] >= 50 then "#eab308" else "#a6bf6d" end 
                 %> <%= item[:val] %>%, #f1f0ee 0);">
              <div class="w-[calc(100%-8px)] h-[calc(100%-8px)] bg-white rounded-full flex items-center justify-center">
                 <span class="text-sm font-bold">
                    <% if item[:label] == "ねむりの質" %>
                      <%= item[:val] >= 80 ? "うとうと" : (item[:val] <= 50 ? "ぐっすり" : "まあまあ") %>
                    <% else %>
                      <%= item[:val] >= 80 ? "高め" : (item[:val] >= 60 ? "まあまあ" : "低め") %>
                    <% end %>
                 </span>
              </div>
            </div>
          </div>
        <% end %>
      </div>
    </div>

    <div class="flex-1 bg-white rounded-[40px] p-6 shadow-sm border border-stone-100 text-center flex flex-col">
      <div class="flex items-center justify-center gap-2 mb-4">
        <span class="flex items-center gap-2 p-2 px-4 bg-stone-50 rounded-full text-emerald-800 text-sm font-bold">
          <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 20 20" fill="currentColor" class="size-5">
            <path fill-rule="evenodd" d="M3.43 2.524A41.29 41.29 0 0 1 10 2c2.236 0 4.43.18 6.57.524 1.437.231 2.43 1.49 2.43 2.902v5.148c0 1.413-.993 2.67-2.43 2.902a41.202 41.202 0 0 1-5.183.501.78.78 0 0 0-.528.224l-3.579 3.58A.75.75 0 0 1 6 17.25v-3.443a41.033 41.033 0 0 1-2.57-.33C1.993 13.244 1 11.986 1 10.573V5.426c0-1.413.993-2.67 2.43-2.902Z" clip-rule="evenodd" />
          </svg>
          <span><%= current_user.name %>さんへのアドバイス</span>
        </span>
      </div>

      <div class="flex flex-col justify-center">
        <% if @display_record %>
          <% advice = @display_record.kampo_advice(@weekly_symptom_names) %>
          <p class="text-sm text-stone-600 leading-relaxed mb-6">「<%= advice[:message] %>」</p>
          <div class="flex items-center justify-center gap-2 mb-3">
            <span class="flex items-center gap-2 p-2 px-4 bg-stone-50 rounded-full text-emerald-800 text-sm font-bold">
              <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="currentColor" class="size-6">
                <path d="m11.645 20.91-.007-.003-.022-.012a15.247 15.247 0 0 1-.383-.218 25.18 25.18 0 0 1-4.244-3.17C4.688 15.36 2.25 12.174 2.25 8.25 2.25 5.322 4.714 3 7.688 3A5.5 5.5 0 0 1 12 5.052 5.5 5.5 0 0 1 16.313 3c2.973 0 5.437 2.322 5.437 5.25 0 3.925-2.438 7.111-4.739 9.256a25.175 25.175 0 0 1-4.244 3.17 15.247 15.247 0 0 1-.383.219l-.022.012-.007.004-.003.001a.752.752 0 0 1-.704 0l-.003-.001Z" />
              </svg>
              <span>オススメの食材</span>
            </span>
          </div>
          <p class="text-sm text-stone-600 leading-relaxed"><%= advice[:foods] %></p>
        <% end %>
      </div>
    </div>
  </div>

  <div class="pb-10">
    <%= link_to "今日の体調を記録する", new_health_record_path, 
        class: "px-20 py-3 bg-[#d17770] text-white rounded-2xl hover:bg-[#cc6a63] shadow-lg transition-all inline-block font-medium" %>
  </div>
</div>