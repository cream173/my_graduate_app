<div class="flex flex-col items-center justify-center gap-4 py-10 min-h-screen bg-[#fcfaf7] py-20">
  <h1 class="text-3xl font-serif">
    今日も一日お疲れさま
  </h1>

  <div class="flex items-baseline mb-6">
    <span class="text-2xl">
      <%= current_user.name %>さん
    </span>
  </div>

  <div class="w-full max-w-md px-6 mb-8">
    <div class="flex justify-between items-end mb-6">
      <h2 class="text-md">今週の体調バランス</h2>
    </div>

    <div class="flex justify-between gap-4">
      <% [
        { label: "ストレス", val: @stress_percent || 0 },
        { label: "からだの疲れ", val: @fatigue_percent || 0 },
        { label: 'ねむりの質', val: @sleep_percent || 0 }
      ].each do |item| %>

        <%
          graph_color = if item[:val] >= 70
                          "#c4232e" # 赤
                        elsif item[:val] >= 50
                          "#eab308" # 黄
                        else
                          "#a6bf6d" # 緑
                        end
        %>

        <div class="flex-1 flex flex-col items-center">
          <span class="text-[10px] pb-3"><%= item[:label] %></span>
          <div class="w-28 h-28 rounded-full flex items-center justify-center mb-2 relative"
               style="background: conic-gradient(<%= graph_color %> <%= item[:val] %>%, #f1f0ee 0);">
            
            <div class="w-[calc(100%-8px)] h-[calc(100%-8px)] bg-white rounded-full flex items-center justify-center">
              <div class="text-center">
                <span class="text-sm font-bold">
                  <% if item[:label] == "ねむりの質" %>
                    <% if item[:val] >= 80 %>
                      うとうと
                    <% elsif item[:val] <= 50 %>
                      ぐっすり
                    <% else %>
                      まあまあ
                    <% end %>
                  <% else %>
                    <% if item[:val] >= 80 %>
                      高め
                    <% elsif item[:val] >= 60 %>
                      まあまあ
                    <% else %>
                      低め
                    <% end %>
                  <% end %>
                </span>
              </div>
            </div>
          </div>
        </div>
      <% end %>
    </div>
  </div>

  <div class="w-full max-w-md mb-8">
    <div class="bg-white rounded-[40px] p-6 shadow-sm border border-stone-100 text-center">
      <div class="flex items-center justify-center gap-2 mb-4">
        <span class="flex items-center gap-2 p-2 px-4 bg-stone-50 rounded-full text-emerald-800 text-sm font-bold">
          <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 20 20" fill="currentColor" class="size-5">
            <path fill-rule="evenodd" d="M3.43 2.524A41.29 41.29 0 0 1 10 2c2.236 0 4.43.18 6.57.524 1.437.231 2.43 1.49 2.43 2.902v5.148c0 1.413-.993 2.67-2.43 2.902a41.202 41.202 0 0 1-5.183.501.78.78 0 0 0-.528.224l-3.579 3.58A.75.75 0 0 1 6 17.25v-3.443a41.033 41.033 0 0 1-2.57-.33C1.993 13.244 1 11.986 1 10.573V5.426c0-1.413.993-2.67 2.43-2.902Z" clip-rule="evenodd" />
          </svg>
          <span><%= current_user.name %>さんへのアドバイス</span>
        </span>
      </div>

      <% if @display_record %>
        <% advice = @display_record.kampo_advice(@weekly_symptom_names) %>
        <div class="advice-card">
          <p class="text-sm text-stone-600 leading-relaxed">
            「<%= advice[:message] %>」
          </p>
        </div>

        <div class="flex items-center justify-center gap-2 my-3">
          <span class="flex items-center gap-2 p-2 px-4 bg-stone-50 rounded-full text-emerald-800 text-sm font-bold">
            <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 20 20" fill="currentColor" class="size-5">
              <path d="m9.653 16.915-.005-.003-.019-.01a20.759 20.759 0 0 1-1.162-.682 22.045 22.045 0 0 1-2.582-1.9C4.045 12.733 2 10.352 2 7.5a4.5 4.5 0 0 1 8-2.828A4.5 4.5 0 0 1 18 7.5c0 2.852-2.044 5.233-3.885 6.82a22.049 22.049 0 0 1-3.744 2.582l-.019.01-.005.003h-.002a.739.739 0 0 1-.69.001l-.002-.001Z" />
            </svg>
            <span><%= current_user.name %>さんにオススメの食材</span>
          </span>
        </div>

        <div class="advice-card">
          <p class="text-sm text-stone-600 leading-relaxed">
            <%= advice[:foods] %>
          </p>
        </div>
      <% end %>
    </div>
  </div>

  <div class="pb-10">
    <%= link_to "今日の体調を記録する", new_health_record_path, 
        class: "px-20 py-3 bg-[#d17770] text-white rounded-2xl hover:bg-[#cc6a63] shadow-lg transition-all inline-block font-medium" %>
  </div>
</div>