<div class="flex flex-col items-center justify-center gap-4 py-10 min-h-screen bg-[#fcfaf7] py-20">
  <h1 class="text-3xl font-serif">
    今日も一日お疲れさま🌱
  </h1>

  <div class="flex items-baseline mb-6">
    <span class="text-2xl">
      <%= current_user.name %>さん
    </span>
  </div>

  <div class="w-full max-w-md px-6 mb-8">
    <div class="flex justify-between items-end mb-6">
      <h2 class="text-xl font-serif">今週の体調バランス</h2>
    </div>

    <div class="flex justify-between gap-4">
      <% [
        { label: "ストレス", val: @stress_percent || 0 },
        { label: "からだの疲れ", val: @fatigue_percent || 0 },
        { label: 'ねむりの質', val: @sleep_percent || 0 }
      ].each do |item| %>

        <%
          graph_color = if item[:val] >= 70
                          "#c4232e" # 赤
                        elsif item[:val] >= 50
                          "#eab308" # 黄
                        else
                          "#a6bf6d" # 緑
                        end
        %>

      <div class="flex-1 flex flex-col items-center">
        <span class="text-[10px] pb-3"><%= item[:label] %></span>
          <div class="w-28 h-28 rounded-full flex items-center justify-center mb-2 relative"
               style="background: conic-gradient(<%= graph_color %> <%= item[:val] %>%, #f1f0ee 0);">
            
            <div class="w-[calc(100%-8px)] h-[calc(100%-8px)] bg-white rounded-full flex items-center justify-center">
              <div class="text-center">
                <span class="text-sm font-bold">
                <% if item[:label] == "ねむりの質" %>
                    <% if item[:val] >= 80 %>
                      うとうと
                    <% elsif item[:val] <= 50 %>
                      ぐっすり
                    <% else %>
                      まあまあ
                    <% end %>
                <% else %>
                  <% if item[:val] >= 80 %>
                    高め
                  <% elsif item[:val] >= 60 %>
                    まあまあ
                  <% else %>
                    低め
                  <% end %>
                <% end %>
              </span>
              </div>
            </div>
          </div>
        </div>
      <% end %>
    </div>
  </div>
  
  <div class="pb-10">
    <%= link_to "体調を記録する", new_health_record_path, 
        class: "px-10 py-4 bg-[#d17770] text-white rounded-2xl hover:bg-[#cc6a63] shadow-lg transition-all inline-block font-medium" %>
  </div>
</div>