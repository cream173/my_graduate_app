<div class="inset-x-0 mt-4 flex flex-col items-center gap-2 pointer-events-none">
  <% if notice.present? %>
    <div class="flex items-center justify-center gap-2 bg-[#8ca864] text-white text-center w-full max-w-lg px-6 py-3 rounded-xl shadow-lg pointer-events-auto">
      <svg xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke-width="1.5" stroke="currentColor" class="size-6">
        <path stroke-linecap="round" stroke-linejoin="round" d="M9 12.75 11.25 15 15 9.75M21 12a9 9 0 1 1-18 0 9 9 0 0 1 18 0Z" />
      </svg>
      <%= notice %>
    </div>
  <% end %>

  <% if alert.present? %>
    <div class="flex items-center justify-center gap-2 bg-[#905a65] text-white text-center w-full max-w-lg px-6 py-3 rounded shadow-lg pointer-events-auto">
      <svg xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke-width="1.5" stroke="currentColor" class="size-6">
        <path stroke-linecap="round" stroke-linejoin="round" d="M12 9v3.75m-9.303 3.376c-.866 1.5.217 3.374 1.948 3.374h14.71c1.73 0 2.813-1.874 1.948-3.374L13.949 3.378c-.866-1.5-3.032-1.5-3.898 0L2.697 16.126ZM12 15.75h.007v.008H12v-.008Z" />
      </svg>
      <%= alert %>
    </div>
  <% end %>
</div>