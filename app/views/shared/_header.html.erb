<header class="w-full border-b bg-[#7a9a3a]">
  <div class="max-w-8xl mx-auto px-4 py-4 flex items-center justify-between">
    
    <!-- ロゴ -->
    <%= link_to root_path, class: "text-xl font-bold text-white" do %>
      からだびより
    <% end %>

    <!-- 右側ボタン -->
    <div class="flex items-center space-x-4">
      <%= link_to "ログイン", new_user_session_path,
        class: "px-4 py-2 text-sm text-gray-600 hover:text-pink-400 transition" %>

      <%= link_to "新規登録", new_user_registration_path,
        class: "px-5 py-2 text-sm bg-green-300 text-white rounded-xl hover:bg-green-500 shadow-sm transition" %>

      <%= link_to "ログアウト", destroy_user_session_path, data: { turbo_method: :delete },
        class: "px-5 py-2 text-sm bg-green-300 text-white rounded-xl hover:bg-green-500 shadow-sm transition" %>
      </div>
</header>